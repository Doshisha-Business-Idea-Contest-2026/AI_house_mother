# LINE Messaging API (get from https://developers.line.biz/console/)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Google Gemini API (get from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Server
FASTAPI_PORT=8084
LOG_LEVEL=INFO

# Timezone (used inside the app; systemd unit also sets TZ)
TZ=Asia/Tokyo

# Public base URL for the Sender switch icon URLs (docs/04 §3.5).
# Must be the Apache-proxied HTTPS origin so LINE can fetch iconUrl.
PUBLIC_BASE_URL=https://linebot.kmchan.jp/ai_house_mother

# Gemini configuration.
# Default: gemini-flash-lite-latest. The rolling alias has a much larger
# free-tier daily quota than the fixed gemini-2.5-flash-lite alias, which
# is capped at 20 requests per day (measured 2026-07).
GEMINI_MODEL=gemini-flash-lite-latest
# When true, bypass Gemini and use seed-based static fallbacks. Handy for
# offline development or rehearsing a Gemini outage during the demo.
GEMINI_MOCK_MODE=false
